{
  "manifest_version": 3,
  "name": "LeetCode Tracker",
  "version": "1.0",
  "description": "Auto-log your LeetCode submissions to your tracker",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:5173/*",
    "https://your-tracker.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://your-tracker.vercel.app/*"
      ],
      "js": ["tracker_bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}